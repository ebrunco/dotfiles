selected-urgent-foreground: #ADAEAE;

background-color: #070808;
background: rgba(0,0,0,0.7);
foreground: #ADAEAE;
border-color: #898979;

color0: #51504D;
color1: #101112;
color2: #1A1B1B;
color3: #4E4E49;
color4: #67675B;
color5: #77766D;
color6: #B5B3A4;
