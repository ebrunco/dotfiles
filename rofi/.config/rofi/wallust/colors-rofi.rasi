alternate-active-background: #676861;
alternate-active-foreground: #ADAEAE;
alternate-normal-background: #070808;
alternate-normal-foreground: #ADAEAE;
alternate-urgent-background: #070808;
alternate-urgent-foreground: #ADAEAE;

selected-active-background: #9E9E92;
selected-active-foreground: #ADAEAE;
selected-normal-background: #9E9E92;
selected-normal-foreground: #ADAEAE;
